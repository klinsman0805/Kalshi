# ── Kalshi credentials ────────────────────────────────────────────────────────
# Generate at: https://kalshi.com/account/profile → API Keys
KALSHI_KEY_ID=your-key-id-here           # The Key ID shown after generation
KALSHI_KEY_FILE=kalshi.key               # Path to downloaded RSA private key file

# ── Environment ───────────────────────────────────────────────────────────────
KALSHI_DEMO=true          # true = use demo.kalshi.co  |  false = live trading
DRY_RUN=true              # true = log only, no real orders placed

# ── Strategy tuning ───────────────────────────────────────────────────────────
TRADE_SIZE_CONTRACTS=5    # contracts per maker quote leg
MAX_POSITION_CONTRACTS=20 # max total contracts held per market
SPREAD_TARGET_CENTS=3     # target bid/ask spread we post (cents)
REQUOTE_THRESHOLD=2       # reprice quotes if mid moves >= this many cents

# ── Files ─────────────────────────────────────────────────────────────────────
POSITIONS_FILE=positions.json
TRADES_FILE=trades.jsonl
LOG_FILE=kalshi_log.jsonl
